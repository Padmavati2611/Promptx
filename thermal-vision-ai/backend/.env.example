# ThermalVision AI Environment Variables

# Application
APP_NAME=ThermalVision AI
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/thermal_vision
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# YOLOv8 Configuration
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
